# ============================================================
#  ENVIRONMENT CONFIGURATION (example)
#  Copy this file to ".env" and change the values.
#  NEVER commit the real .env file to GitHub.
# ============================================================

# --- Core ---
# Generate a new key, e.g.:  python -c "import secrets;print(secrets.token_urlsafe(50))"
SECRET_KEY=replace-this-with-a-long-random-secret

# Set DEBUG=False in production. Keep True only on your local machine.
DEBUG=True

# Comma-separated list of allowed hosts/domains.
ALLOWED_HOSTS=127.0.0.1,localhost

# --- Session ---
# Idle timeout in seconds (1800 = 30 minutes).
SESSION_COOKIE_AGE=1800
SESSION_EXPIRE_AT_BROWSER_CLOSE=True

# --- Production security flags ---
# Turn these ON (True) only when the app runs behind real HTTPS.
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0
# CSRF_TRUSTED_ORIGINS=https://yourdomain.com

# --- Database (optional) ---
# Leave commented to use the default SQLite database (good for dev/demo).
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=secure_inventory
# DB_USER=postgres
# DB_PASSWORD=change-me
# DB_HOST=127.0.0.1
# DB_PORT=5432
